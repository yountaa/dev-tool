# --- Alertmanager-ы (вкладки окружений) ---
# Каждая переменная alert_<имя>=<url> = отдельная вкладка в вебе.
alert_dev=http://alertmanager.dev.svc:9093
alert_stage=http://alertmanager.stage.svc:9093
alert_prod=http://alertmanager.prod.svc:9093

# --- Git-хранилище конфигов (save_hub) ---
# Куда коммитятся созданные silence-конфиги. Авторизация через deploy-токен.
GIT_REPO_URL=https://gitlab.example.com/infra/silences-hub.git
GIT_USER=silence-bot
GIT_TOKEN=glpat-xxxxxxxxxxxxxxxx
GIT_BRANCH=main
GIT_LOCAL_DIR=./.hub-repo

# --- Шедулер ---
# Cron-выражение проверки расписаний (по умолчанию каждые 5 минут).
SILENCE_CRON=*/5 * * * *
# Таймзона, в которой пользователь задаёт время окон в расписании.
SILENCE_TZ=Europe/Moscow

# --- Авторизация (oauth2-proxy + Keycloak перед вебом) ---
# true — личность создателя берём из заголовка от oauth2-proxy (имя из Keycloak),
# поле «Создатель» в вебе только показывается. false (по умолчанию) — прокси нет,
# ходим напрямую, автор = AUTH_FALLBACK_USER.
AUTH_ENABLED=false
# Заголовок, в который oauth2-proxy кладёт имя (preferred_username из Keycloak).
AUTH_USER_HEADER=X-Forwarded-Preferred-Username
# Имя автора, когда авторизации нет (локальная разработка).
AUTH_FALLBACK_USER=local
