# ============================================================================
#  dev-tool — пример конфигурации. Скопируй в .env и поправь под себя:
#    cp .env.example .env
#
#  Файл читают:
#   • docker-compose.yml      — порты (блок 1);
#   • backend (env_file: .env) — всё, что относится к бэку (блоки 2–5);
#   • docker-compose.auth.yml — Keycloak/oauth2-proxy (блок 6).
# ============================================================================


# ─── 1. Порты публикации (docker-compose.yml) ───────────────────────────────
# На каких портах хоста слушать сервисы локального стенда.
FRONTEND_PORT=8080         # веб без авторизации: http://localhost:8080
BACKEND_PORT=8000          # API бэкенда:        http://localhost:8000
ALERTMANAGER_PORT=9093     # тестовый Alertmanager


# ─── 2. Alertmanager-ы = вкладки окружений (backend) ────────────────────────
# Каждая переменная вида  alert_<имя>=<url>  превращается в отдельную вкладку
# окружения в вебе. Имя (часть после alert_) уходит в нижний регистр.
# URL наружу не отдаются — только имена.
#
# Можно указать ОДНУ ноду (один URL) или НЕСКОЛЬКО через запятую (HA-кластер AM):
# читаем со всех нод, silence пишем на первую живую (кластер разнесёт госсипом).
alert_dev=http://alertmanager.dev.svc:9093                                   # одна нода
alert_stage=http://alertmanager.stage.svc:9093
alert_prod=http://am-1.prod.svc:9093,http://am-2.prod.svc:9093              # несколько нод (HA)
# Для локального стенда (один контейнер AM на всех):
# alert_local=http://alertmanager:9093

# Источник определений алертов на окружение: rules_<имя>=<url> — база Prometheus
# ИЛИ vmalert (у обоих одинаковый GET /api/v1/rules). По нему вкладка «Алерты»
# показывает ВСЕ правила, а Alertmanager лишь помечает, какие горят/заглушены.
# Необязательно: нет переменной — вкладка откатывается на живые алерты из AM.
#
# Так же одна нода или список через запятую (HA vmalert/Prometheus): правила
# собираем со ВСЕХ нод и дедупим по (имя, выражение).
# rules_dev=http://prometheus.dev.svc:9090                                    # одна нода
# rules_prod=http://vmalert-1.prod.svc:8880,http://vmalert-2.prod.svc:8880   # несколько нод (HA)
# Для локального стенда:
# rules_local=http://prometheus:9090


# ─── 3. Git-хранилище конфигов = save_hub (backend) ─────────────────────────
# Куда коммитятся правила (silence-конфиги). Это «база» с историей: видно, кто
# что создал/выключил/удалил. Доступ — по deploy-токену.
# Если GIT_REPO_URL/USER/TOKEN пустые — git выключается, работаем только локально.
GIT_REPO_URL=https://gitlab.example.com/infra/silences-hub.git
GIT_USER=silence-bot
GIT_TOKEN=glpat-xxxxxxxxxxxxxxxx
GIT_BRANCH=main
GIT_LOCAL_DIR=./.hub-repo   # локальная папка клона (в docker примонтирована в ./data)


# ─── 4. Шедулер расписаний (backend) ────────────────────────────────────────
SILENCE_CRON=*/5 * * * *    # как часто проверять и доставлять расписания
SILENCE_TZ=Europe/Moscow    # таймзона, в которой задаётся время окон


# ─── 5. Авторизация: кто создаёт/меняет правила (backend) ───────────────────
# AUTH_ENABLED=true  → имя берётся из заголовка от oauth2-proxy (логин в Keycloak),
#                      поле «Создатель» в вебе только показывается;
# AUTH_ENABLED=false → прокси нет, имя вводится РУКАМИ в форме (как раньше),
#                      а фолбэк AUTH_FALLBACK_USER используется для действий без
#                      формы (вкл/выкл/удаление) в git-коммитах.
AUTH_ENABLED=false
AUTH_USER_HEADER=X-Forwarded-Preferred-Username   # заголовок с именем от oauth2-proxy
AUTH_FALLBACK_USER=local                          # автор, когда авторизации нет


# ─── 6. Keycloak + oauth2-proxy (только docker-compose.auth.yml) ────────────
# Используется лишь в режиме с авторизацией:
#   docker-compose -f docker-compose.yml -f docker-compose.auth.yml up --build
#   вход → http://localhost:4180
#
# Тестовый стенд работает и без этих переменных (есть дефолты). Меняй их, когда
# подключаешь СВОЙ Keycloak.
KEYCLOAK_REALM=silences
# Базовый URL Keycloak для БРАУЗЕРА (страница логина):
KEYCLOAK_BROWSER_URL=http://localhost:8081
# Базовый URL Keycloak, по которому до него достучится сам oauth2-proxy (внутри сети).
# Для НАСТОЯЩЕГО Keycloak, доступного по одному адресу и браузеру, и серверу —
# выстави обе переменные одинаково (https://keycloak.example.com).
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
# Клиент, заведённый в Keycloak (см. auth/realm-silences.json для тестового):
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=secret123
# Секрет cookie — РОВНО 16, 24 или 32 байта. Сгенерировать:
#   openssl rand -base64 32 | head -c 32
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdef0123456789abcdef
# Куда Keycloak вернёт после логина (должно совпадать с redirectUris клиента):
OAUTH2_PROXY_REDIRECT_URL=http://localhost:4180/oauth2/callback
