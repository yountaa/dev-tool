# =============================================================================
#  dev-tool — переменные окружения
#
#  Применение:   cp .env.example .env   и заполнить значения под свой стенд.
#  Кто читает:   docker-compose.yml (порты и сервис Postgres) и
#                backend (env_file: .env — все остальные переменные).
#
#  Значение «по умолчанию» указано там, где переменную можно не задавать.
# =============================================================================


# -----------------------------------------------------------------------------
#  Порты публикации приложения (docker-compose.yml)
# -----------------------------------------------------------------------------
FRONTEND_PORT=8080          # веб-интерфейс → http://localhost:8080
BACKEND_PORT=8000           # API бэкенда   → http://localhost:8000

# Куда внутренний nginx фронта проксирует API (/silences/, /victoria/, /access/, /health). Браузер ходит
# только на фронт, а nginx форвардит запросы на бэкенд по этому адресу — поэтому
# нужен ПОЛНЫЙ адрес (схема://хост:порт), доступный С СЕРВЕРА ФРОНТА (наружу бэкенд
# открывать необязательно). Порт = BACKEND_PORT, на котором опубликован бэкенд.
# НЕСКОЛЬКО бэкендов (отказоустойчивость) — через запятую, как alert_*/rules_*:
# фронт сам балансирует (least_conn) и временно исключает упавшую ноду.
#   один сервер / docker-compose:  http://backend:8000
#   разные серверы:                http://10.0.0.5:8000
#   HA-кластер беков (список):     http://10.0.0.5:8000,http://10.0.0.6:8000,http://10.0.0.7:8000
BACKEND_URL=http://backend:8000


# =============================================================================
#  МОДУЛЬ silences — вкладка «Silence Manager»
#  (переменные ниже до блока «Авторизация» относятся к этому модулю:
#   alert_*, rules_*, STORAGE_BACKEND, PG_*, GIT_*, SILENCE_*, CLEANUP_*)
# =============================================================================

# --- Окружения = вкладки окружения (Alertmanager) ----------------------------
#  Формат:  alert_<имя>=<url>[,<url2>...]
#  Каждая переменная даёт отдельную вкладку окружения. Имя (после alert_)
#  приводится к нижнему регистру. URL наружу не отдаются — только имена.
#  HA: несколько нод через запятую — читаем со всех, silence пишем на первую
#  живую (кластер Alertmanager разносит его по gossip сам).
alert_dev=http://alertmanager.dev.svc:9093
alert_prod=http://am-1.prod.svc:9093,http://am-2.prod.svc:9093


# -----------------------------------------------------------------------------
#  Источник определений алертов для вкладки «Алерты» (Prometheus или vmalert)
#
#  Формат:  rules_<имя>=<url>[,<url2>...]    (<имя> совпадает с именем окружения)
#  Берётся через GET /api/v1/rules: вкладка показывает все правила, а
#  Alertmanager помечает, какие горят/заглушены. Несколько нод — через запятую.
#  Необязательно: без переменной вкладка показывает живые алерты из Alertmanager.
# -----------------------------------------------------------------------------
rules_dev=http://prometheus.dev.svc:9090
rules_prod=http://vmalert-1.prod.svc:8880,http://vmalert-2.prod.svc:8880


# -----------------------------------------------------------------------------
#  Хранилище правил и истории
#
#  local    — git/файлы; одна нода приложения (см. блок «Git»).
#  postgres — общая БД; несколько нод (см. блок «Postgres»). Все ноды читают/пишут
#             одну базу, шедулер координируется advisory-локом (тикает одна нода).
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local


# -----------------------------------------------------------------------------
#  Postgres  (используется только при STORAGE_BACKEND=postgres)
#
#  Достаточно прав на CREATE TABLE — таблицы configs и history создаются
#  автоматически при старте. Задать можно одной строкой PG_DSN ИЛИ по частям.
# -----------------------------------------------------------------------------
# PG_DSN=postgresql://devtool:secret@pg-cluster:5432/devtool
PG_HOST=localhost           # для docker-стенда укажи имя сервиса: PG_HOST=postgres
PG_PORT=5432
PG_DB=devtool
PG_USER=devtool
PG_PASSWORD=secret


# -----------------------------------------------------------------------------
#  Git-хранилище  (используется только при STORAGE_BACKEND=local)
#
#  Куда коммитятся конфиги правил (история изменений хранится в git).
#  Доступ — по deploy-токену. Если GIT_REPO_URL/USER/TOKEN пустые — git выключен,
#  работа идёт только в локальной папке GIT_LOCAL_DIR.
# -----------------------------------------------------------------------------
GIT_REPO_URL=
GIT_USER=
GIT_TOKEN=
GIT_BRANCH=main
GIT_LOCAL_DIR=./.hub-repo   # папка локального клона (в docker примонтирована в ./data)


# -----------------------------------------------------------------------------
#  Шедулер расписаний
# -----------------------------------------------------------------------------
SILENCE_CRON=*/5 * * * *    # как часто проверять и доставлять расписания в Alertmanager
SILENCE_TZ=Europe/Moscow    # таймзона ввода и показа времени в вебе (Alertmanager работает в UTC)


# -----------------------------------------------------------------------------
#  Авто-очистка (три независимых параметра: когда чистить + два срока хранения)
# -----------------------------------------------------------------------------
# КОГДА запускать очистку (само расписание, cron). По умолчанию 1-го числа в 03:00.
CLEANUP_CRON=0 3 1 * *
# Сколько дней хранить ЖУРНАЛ ИСТОРИИ (кто/что/когда менял). Старше — стирается.
HISTORY_RETENTION_DAYS=30
# Сколько дней хранить УДАЛЁННЫЕ ПРАВИЛА (мягко удалённые: deleted_at / папка old/).
# Старше — удаляются окончательно.
DELETED_RULES_RETENTION_DAYS=30


# =============================================================================
#  ОБЩЕЕ для всех модулей — Авторизация и RBAC
# =============================================================================

# --- Авторизация (кто вошёл; в silences — автор создания/изменения правил) ----
#  false — без входа: имя создателя вводится в форме; для действий без формы
#          (вкл/выкл/удаление) автором ставится AUTH_FALLBACK_USER.
#  true  — имя берётся из заголовка AUTH_USER_HEADER, который проставляет
#          обратный прокси (oauth2-proxy/Keycloak); поле в форме только показывается.
AUTH_ENABLED=false
AUTH_USER_HEADER=X-Forwarded-Preferred-Username
AUTH_FALLBACK_USER=local
# Заголовок со списком групп Keycloak (oauth2-proxy отдаёт через запятую) — нужен
# для RBAC ниже. Меняй, только если у прокси другой заголовок.
AUTH_GROUPS_HEADER=X-Forwarded-Groups


# =============================================================================
#  МОДУЛЬ victoria — вкладка «Victoria Metrics»
#
#  Каждый КЛАСТЕР = одна вкладка. Имя <env> после префикса = имя вкладки (в нижнем
#  регистре). Несколько нод компонента (HA) — через запятую (читаем с первой живой).
#
#  Какая переменная на какую под-вкладку влияет:
#    vm_<env>       → под-вкладки Graph и TSDB Status   (ОБЯЗАТЕЛЬНАЯ: адрес vmselect,
#                     Prometheus-совместимый; обычно .../select/0/prometheus)
#    vmagent_<env>  → под-вкладка Targets               (опц.: адрес vmagent)
#    vmalert_<env>  → под-вкладка Rules                 (опц.: адрес vmalert)
#  Нет vmagent_/vmalert_ → соответствующей под-вкладки просто не будет.
# =============================================================================

# --- Пример 1: ЧИСТАЯ Victoria Metrics (свой vmselect/vmagent/vmalert) --------
# Полноценный кластер: будут все под-вкладки (Graph, Targets, Rules, TSDB Status).
vm_dev=http://vmselect.dev.svc:8481/select/0/prometheus     # Graph + TSDB Status
vmagent_dev=http://vmagent.dev.svc:8429                     # Targets
vmalert_dev=http://vmalert.dev.svc:8880                     # Rules

# Кластер ТОЛЬКО под хранение (без vm-agent/vm-alert) — только Graph + TSDB Status,
# вкладок Targets/Rules не будет. Тут же показан HA (2 ноды vmselect через запятую):
vm_store=http://vmselect-1.svc:8481/select/0/prometheus,http://vmselect-2.svc:8481/select/0/prometheus

# --- Пример 2: PROMETHEUS-стек, метрики хранятся в Victoria Metrics -----------
# Prometheus скрейпит и remote_write'ит в VM, алерты — свои + Alertmanager. Тогда:
#   метрики (Graph/TSDB Status) ЧИТАЕМ из VM, а Targets/Rules берём у самого
#   Prometheus (он Prometheus-совместим, отдаёт /api/v1/targets и /api/v1/rules).
vm_promstack=http://vmselect.svc:8481/select/0/prometheus   # Graph + TSDB Status (из VM)
vmagent_promstack=http://prometheus.svc:9090                # Targets  ← сам Prometheus
vmalert_promstack=http://prometheus.svc:9090                # Rules    ← сам Prometheus

# --- Мультитенантный кластер (данные в разных тенантах) -----------------------
# Пиши ПОЛНЫЙ путь на каждый тенант, подпись — через ДВОЙНОЕ подчёркивание:
#   vm_<cluster>__<подпись>=<полный URL с нужным accountID в пути>
# Кластер станет ОДНОЙ вкладкой + селектор тенанта. Тенант влияет только на чтение
# (Graph и TSDB Status); vmagent_/vmalert_ — общие на кластер, тенант их не трогает.
# ВАЖНО: <cluster>/<подпись> — это ИМЯ env-переменной → только [A-Za-z0-9_], дефисы
# нельзя (docker молча выкинет). Двоеточие в accountID:projectID (5:2) — можно, оно
# в ЗНАЧЕНИИ (URL), а не в имени.
vm_shared__platform=http://vmselect.svc:8481/select/0/prometheus
vm_shared__billing=http://vmselect.svc:8481/select/5:2/prometheus
vm_shared__analytics=http://vmselect.svc:8481/select/7/prometheus
vmagent_shared=http://vmagent.svc:8429
vmalert_shared=http://vmalert.svc:8880


# -----------------------------------------------------------------------------
#  Один кластер под ОДНИМ именем в ОБОИХ модулях (silences + victoria)
#
#  Модули независимы, но одинаковое имя окружения даёт вкладку «prod» и в Silence
#  Manager, и в Victoria Metrics — удобно держать кластер под одним именем везде.
#  (Имена сопоставляются по суффиксу после префикса, регистр → нижний.)
#
#    alert_prod=http://alertmanager.prod.svc:9093     # silences: вкладка окружения
#    rules_prod=http://vmalert.prod.svc:8880          # silences: источник правил
#    vm_prod=http://vmselect.prod.svc:8481/select/0/prometheus   # victoria: Graph/TSDB
#    vmagent_prod=http://vmagent.prod.svc:8429                    # victoria: Targets
#    vmalert_prod=http://vmalert.prod.svc:8880                    # victoria: Rules
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
#  RBAC — доступ к вкладкам (модулям) по группам Keycloak
#
#  Работает только при AUTH_ENABLED=true (без входа групп нет — доступ не режется).
#  Группы приходят в заголовке AUTH_GROUPS_HEADER. Имена групп сверяются ТОЧНО
#  (регистр и ведущий слэш важны: Keycloak часто отдаёт «/team-oncall»). Чтобы
#  увидеть, что реально приходит — открой /access/me, там есть поле groups.
#  Правила:
#    - RBAC_ENABLED=false → всем видно всё (по умолчанию).
#    - access_<module>=group1,group2 → какие группы видят этот модуль (вкладку).
#      НЕСКОЛЬКО групп — через запятую (достаточно попасть в любую = логика OR).
#      Модуль без своей access_* виден всем. id модулей: silences, victoria.
#    - access_<module>=* → вкладка открыта ВСЕМ вошедшим (любая группа Keycloak
#      и даже пользователь без групп). Публичная вкладка при включённом RBAC.
#    - RBAC_ADMIN_GROUP=grp1,grp2 → эти группы видят ВСЕ вкладки. Тоже можно
#      перечислить НЕСКОЛЬКО через запятую.
#  Бэкенд и прячет вкладку во фронте, и возвращает 403 на её API (двойная защита).
# -----------------------------------------------------------------------------
RBAC_ENABLED=false
RBAC_ADMIN_GROUP=observability-admins,platform-admins
access_silences=team-oncall,team-sre
access_victoria=team-metrics
